# Example local configuration for development and Docker.
# Do not commit real secrets, API keys, credentials, or service account material.
# Future GCP-related settings can be added here as non-secret placeholders only.

APP_NAME=PAYBACK Lightweight Assistant
APP_VERSION=0.6.0
ENVIRONMENT=local
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
CATALOG_PATH=app/data/products.json
INTENT_BACKEND=rules
RETRIEVAL_BACKEND=keyword
DEFAULT_TOP_K=5
MAX_TOP_K=20

# Stage 8A BigQuery catalog foundation.
# These are inert by default and should not require local GCP credentials.
GCP_PROJECT_ID=
GCP_LOCATION=europe-west1
GCP_REGION=europe-west1
BIGQUERY_DATASET=payback_catalog
BIGQUERY_PRODUCTS_TABLE=products
BIGQUERY_LOCATION=europe-west1
BIGQUERY_VECTOR_TOP_K=25
BIGQUERY_VECTOR_INDEX=products_embedding_idx

# Stage 8B optional Vertex AI embedding provider.
# The default local app does not use these values.
VERTEX_AI_LOCATION=
VERTEX_EMBEDDING_MODEL=text-embedding-005
VERTEX_EMBEDDING_DIMENSIONS=

# Stage 9B optional Vertex/Gemini structured intent backend.
# The default app still uses INTENT_BACKEND=rules.
VERTEX_INTENT_MODEL=gemini-3.5-flash
INTENT_LLM_TIMEOUT_SECONDS=3

# GCP deployment variables
# GCP_REGION=europe-west1
# ARTIFACT_REPOSITORY=payback-assistant
# IMAGE_NAME=payback-lightweight-assistant
# IMAGE_TAG=latest
# SERVICE_NAME=payback-lightweight-assistant
# CLOUD_RUN_SERVICE_ACCOUNT_NAME=payback-assistant-runtime
# CLOUD_RUN_SERVICE_ACCOUNT=payback-assistant-runtime@your-project-id.iam.gserviceaccount.com
# CLOUD_RUN_URL=https://your-service-url.a.run.app
